# ── Database (Neon Postgres) ──────────────────────────────────────────────────

# Pooled connection string from Neon's connection pooling tab (PgBouncer).
# Used by Prisma at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/companio?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection string from Neon. Required for prisma migrate dev
# because PgBouncer does not support DDL transactions.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/companio?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────────

# Random 32-char secret used to sign JWTs and cookies. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-char-secret"

# Full public URL of your deployment (no trailing slash).
AUTH_URL="https://your-app.vercel.app"

# ── Razorpay ──────────────────────────────────────────────────────────────────

# API key ID from the Razorpay dashboard (safe to expose in client bundles).
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"

# API key secret — NEVER expose in client bundles or commit to git.
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# Webhook signing secret from Razorpay dashboard → Webhooks → Secret.
# Used in /api/razorpay/webhook to verify HMAC-SHA256 signatures.
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# ── Frontend data client ──────────────────────────────────────────────────────

# Controls which DataClient implementation is used (see lib/dataClient.ts).
# 'local' = localStorage mock (default, no DB needed).
# 'http'  = real API routes (requires DATABASE_URL + AUTH_SECRET).
NEXT_PUBLIC_DATA_CLIENT="local"
